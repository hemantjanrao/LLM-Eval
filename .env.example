# Copy this to .env when you want to run LLM-as-judge metrics.
OPENAI_API_KEY=

# Ragas publishes anonymous analytics by default. Set this if you prefer local-only learning.
RAGAS_DO_NOT_TRACK=true

# DeepEval can upload traces/results after login. Keep examples local unless you choose otherwise.
DEEPEVAL_TELEMETRY_OPT_OUT=YES

